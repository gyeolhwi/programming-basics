    c.id,
    c.board_id,
    c.parent_id,
    c.writer_id,
    c.create_date,
    ct.level + 1,
    concat(ct.path, ",", c.id) as path
from
    comment c
    left outer join comment_tree ct on (c.parent_id = ct.id)
) [42122-200]
