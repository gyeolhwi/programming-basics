2024-09-09 11:15:08 jdbc[14]: exception
org.h2.jdbc.JdbcSQLSyntaxErrorException: Table "COMMENTS" not found; SQL statement:
WITH RECURSIVE CommentTree AS (
    -- 기본 댓글 (최상위 댓글)들을 선택
    SELECT 
        id,
        post_id,
        parent_id,
        content,
        author,
        created_at,
        0 AS level, -- 최상위 댓글의 계층 레벨을 0으로 설정
        CAST(id AS CHAR(255)) AS path -- 트리 경로를 설정하기 위한 필드
    FROM 
        comments
    WHERE 
        parent_id IS NULL
    
    UNION ALL
    
    -- 재귀적으로 댓글의 하위 댓글들을 선택
    SELECT 
        c.id,
        c.post_id,
        c.parent_id,
        c.content,
        c.author,
        c.created_at,
        ct.level + 1, -- 상위 댓글의 레벨보다 1 증가
        CONCAT(ct.path, ',', c.id) AS path -- 트리 경로를 업데이트
    FROM 
        comments c
    JOIN 
        CommentTree ct ON c.parent_id = ct.id
) [42102-200]
